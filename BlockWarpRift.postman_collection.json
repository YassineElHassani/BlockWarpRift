            "description": "Negative test — `BTC` is not a supported currency, should return 400 Bad Request."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Payment — Missing Amount (expect 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
