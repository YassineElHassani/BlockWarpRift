{
  "info": {
    "name": "BlockWarpRift API",
    "description": "Full API test suite for BlockWarpRift — crypto payment gateway (ETH on Sepolia).\n\nHow to use:\n1. Import this collection into Postman.\n2. Import BlockWarpRift.postman_environment.json as well.\n3. Select the \"BlockWarpRift\" environment.\n4. Run **Auth / Register** then **Auth / Login** — the `bearerToken` is automatically saved.\n5. Run **Users / Update Wallet** to connect a wallet address.\n6. All protected endpoints will use the saved token automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "description": "Base URL for the API. Override in the environment for staging/production."
    },
    {
      "key": "bearerToken",
      "value": "",
      "description": "JWT access token. Automatically set by the Login request test script."
    },
    {
      "key": "paymentId",
      "value": "",
      "description": "MongoDB _id of a payment request. Automatically set by the Create Payment test script."
    },
    {
      "key": "userId",
      "value": "",
      "description": "User ID. Automatically set by the Register test script."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Public endpoints — no Bearer token required.",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"email\": \"merchant@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Register a new merchant account.\n\n**Validation:**\n- `email` — valid email format\n- `password` — 8–64 characters\n\n**Response:** `{ message, user: { id, email, role, walletAddress } }`"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response has user object with expected fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('user');",
                  "  pm.expect(body.user).to.have.property('id');",
                  "  pm.expect(body.user).to.have.property('email');",
                  "  pm.expect(body.user).to.have.property('role');",
                  "  pm.expect(body.user).to.have.property('walletAddress');",
                  "  pm.collectionVariables.set('userId', body.user.id);",
                  "  pm.environment.set('userId', body.user.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register — Duplicate Email (expect 409)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"email\": \"merchant@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Negative test — registering the same email twice should return 409 Conflict."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 409 Conflict', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"email\": \"merchant@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Login and receive a JWT access token.\n\n**Response:** `{ access_token, user: { id, email, role, walletAddress } }`\n\nThe test script automatically saves `access_token` to `bearerToken`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains access_token and user', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('access_token');",
                  "  pm.expect(body.access_token).to.be.a('string').and.not.empty;",
                  "  pm.expect(body).to.have.property('user');",
                  "  pm.expect(body.user).to.have.property('id');",
                  "  pm.expect(body.user).to.have.property('walletAddress');",
                  "",
                  "  pm.collectionVariables.set('bearerToken', body.access_token);",
                  "  pm.environment.set('bearerToken', body.access_token);",
                  "  pm.collectionVariables.set('userId', body.user.id);",
                  "  pm.environment.set('userId', body.user.id);",
                  "  console.log('Bearer token saved successfully.');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — Wrong Password (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"email\": \"merchant@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "description": "Negative test — should return 401 Unauthorized."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401 Unauthorized', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — Non-existent Email (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"email\": \"nobody@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Negative test — non-existent email should return 401 Unauthorized."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401 Unauthorized', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "description": "User management endpoints.\n\nInherits Bearer auth from collection root.",
      "item": [
        {
          "name": "Update Wallet Address",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/wallet",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "wallet"
              ]
            },
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"walletAddress\": \"0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18\"\n}"
            },
            "description": "Connect/update the merchant's MetaMask wallet address.\n\nThis must be done before creating any payment requests — payments are sent directly to this address.\n\n**Response:** `{ walletAddress }`"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains walletAddress', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('walletAddress');",
                  "  pm.expect(body.walletAddress).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "description": "Retrieve a single user by their ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('User has expected fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body._id || body.id).to.exist;",
                  "  pm.expect(body).to.have.property('Email');",
                  "  pm.expect(body).to.have.property('Role');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Users (ADMIN)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "List all users. **Requires ADMIN role.**\n\nMerchants will receive 403 Forbidden."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 403', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 403]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Response is an array', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete User (ADMIN)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/users/000000000000000000000000",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "000000000000000000000000"
              ]
            },
            "description": "Delete a user by ID. **Requires ADMIN role.**\n\nUses a dummy ObjectId to avoid deleting real data during testing."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 403', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 403]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Payment",
      "description": "Payment request management. All endpoints require a valid Bearer token.\n\nThe merchant must have a connected wallet address before creating payments.\n\nInherits Bearer auth from collection root.",
      "item": [
        {
          "name": "Create Payment (ETH)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payment",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payment"
              ]
            },
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"amount\": 0.01,\n  \"currency\": \"ETH\",\n  \"description\": \"Order #1001 — 1 month subscription\"\n}"
            },
            "description": "Create a new ETH payment request.\n\nUses the merchant's connected wallet address. Returns a QR code (EIP-681 URI) and a 15-minute expiry.\n\n**Prerequisites:** Run **Users / Update Wallet** first.\n\n**Currency:** `ETH` only.\n\nReturns 400 if no wallet is connected."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response has required payment fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('_id');",
                  "  pm.expect(body).to.have.property('walletAddress');",
                  "  pm.expect(body).to.have.property('qrCode');",
                  "  pm.expect(body).to.have.property('expiresAt');",
                  "  pm.expect(body.status).to.equal('PENDING');",
                  "  pm.expect(body.currency).to.equal('ETH');",
                  "  pm.collectionVariables.set('paymentId', body._id);",
                  "  pm.environment.set('paymentId', body._id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Payment — No Wallet (expect 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payment",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payment"
              ]
            },
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"amount\": 0.05,\n  \"currency\": \"ETH\"\n}"
            },
            "description": "Negative test — if the merchant has not connected a wallet, the API should return 400 Bad Request.\n\n**Note:** This only fails if the wallet was never set. If you already ran **Update Wallet**, this test will return 201 instead."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 Bad Request (no wallet)', () => {",
                  "  // This test passes only if the merchant has no wallet connected.",
                  "  // If wallet is connected, expect 201 instead.",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 201]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Payment — Invalid Currency (expect 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payment",
              "host": [
                "{{baseUrl}}"
              ],
