        {
          "name": "Get Payment Public Endpoint",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/payment/public/{{paymentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payment",
                "public",
                "{{paymentId}}"
              ]
            },
            "description": "Public endpoint — retrieve a payment by ID without authentication.\n\nUsed by the checkout page to display payment details to the customer."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Payment has expected camelCase fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body._id).to.equal(pm.collectionVariables.get('paymentId'));",
                  "  pm.expect(body).to.have.property('amount');",
                  "  pm.expect(body).to.have.property('currency');",
                  "  pm.expect(body).to.have.property('walletAddress');",
                  "  pm.expect(body).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Transaction",
      "description": "Transaction history for on-chain payments.\n\nInherits Bearer auth from collection root.",
      "item": [
        {
          "name": "Get Merchant Transactions (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transaction?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transaction"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Items per page (default: 20)"
                }
              ]
            },
            "description": "Returns a paginated list of transactions for the authenticated merchant."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has paginated structure', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body.data).to.be.an('array');",
                  "  pm.expect(body).to.have.property('total');",
                  "});"
                ]
              }
            }
          ]
        },
