              ]
            },
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"currency\": \"ETH\"\n}"
            },
            "description": "Negative test — missing required `amount` field should return 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
