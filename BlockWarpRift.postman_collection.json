            }
          ]
        },
        {
          "name": "Get Transactions by Payment ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transaction/{{paymentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transaction",
                "{{paymentId}}"
