# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017/blockwarprift

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=7d

# ─── Encryption (AES-256 — 64 hex chars = 32 bytes) ─────────────────────────
ENCRYPTION_KEY=your-64-hex-char-encryption-key-here

# ─── Blockchain (Alchemy — Ethereum Sepolia) ─────────────────────────────────
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NETWORK=sepolia

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Mongo Express UI ───────────────────────────────────────────────────────
ME_USERNAME=admin
ME_PASSWORD=pass

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api
